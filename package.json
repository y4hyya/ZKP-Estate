{
  "name": "zkp-estate",
  "version": "1.0.0",
  "description": "Privacy-preserving rental protocol using TLSNotary attestations",
  "main": "index.js",
  "scripts": {
    "dev:node": "hardhat node",
    "dev:deploy": "hardhat run scripts/deploy.cjs --network localhost",
    "build": "hardhat compile",
    "test": "hardhat test",
    "test:unit": "hardhat test test/unit/",
    "test:tls": "hardhat test",
    "test:type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "scripts:deploy": "hardhat run scripts/deploy.cjs",
    "scripts:createPolicy": "hardhat run scripts/createPolicy.cjs",
    "scripts:startLease": "hardhat run scripts/startLease.cjs",
    "scripts:confirm": "hardhat run scripts/ownerConfirm.cjs",
    "scripts:refund": "hardhat run scripts/timeoutRefund.cjs",
    "scripts:e2e": "hardhat run scripts/e2e-test.cjs",
    "scripts:demo-tls": "hardhat run scripts/demo-tls.cjs",
    "wizard": "node scripts/input-wizard.cjs",
    "frontend": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "typechain": "hardhat typechain",
    "coverage": "hardhat coverage",
    "clean": "hardhat clean && rm -rf artifacts typechain-types"
  },
  "keywords": [
    "tlsnotary",
    "rent",
    "estate",
    "hardhat",
    "ethereum",
    "privacy"
  ],
  "author": "ZKP-Estate Team",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "chai": "^4.3.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "ethers": "^6.0.0",
    "hardhat": "^2.19.0",
    "hardhat-gas-reporter": "^1.0.9",
    "prettier": "^3.0.0",
    "solidity-coverage": "^0.8.0",
    "ts-node": "^10.0.0",
    "typechain": "^8.3.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "axios": "^1.6.0",
    "dotenv": "^16.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
